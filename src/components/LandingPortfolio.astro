---

<section class="portfolio-area bg_white section-padding-bottom overflow-hidden">
  <div class="container container-semi-large">
    <div class="row align-items-center gy-lg-5 gy-4">
      <div class="col-lg-12">
        <div class="section-title-three-sub black-sub sub-black-border">
          <span
            class="d-inline-block position-relative fnt-weight-500 fade_left"
            >OUR PORTFOLIO</span
          >
        </div>
      </div>
      <div class="col-lg-8">
        <div class="section-title-two">
          <h2 class="h2 text-black">Explore selected projects</h2>
        </div>
      </div>
      <div class="col-lg-4 text-lg-end">
        <a
          class="common-design-btn only-border border-black btn-trigger btn-bounce"
          href="portfolio-grid.html"
        >
          <span class="btn-flip">
            <span data-text="See Portfolios">See Portfolios</span>
          </span>
        </a>
      </div>
    </div>
    <div class="row justify-content-center">
      <div class="col-xl-10 portfolio-box-wrap portfolio-text-wrap">
        <div class="portfolio-box text-center">
          <h2
            class="portfolio-name mt-lg-2 portfolio-title-wrap portfolio-pin-box portfolio__text text-uppercase text-black"
          >
            WORKS
          </h2>
          <div
            class="d-flex flex-column mt-3 mt-lg-0 gap-4 gap-lg-5 portfolio-pin-wrapper"
          >
            <div class="portfolio-item-single portfolio-pin-box">
              <img src="assets/images/portfolio/pf-3-1.webp" alt="" />
              <div class="portfolio-item-info text-start w-100">
                <h3 class="h3 mb-2">
                  <a href="#">Ghar Ka Khana</a>
                </h3>
                <p>Next.js</p>
              </div>
            </div>
            <div class="portfolio-item-single portfolio-pin-box">
              <img src="assets/images/portfolio/pf-3-2.webp" alt="" />
              <div class="portfolio-item-info text-start w-100">
                <h3 class="h3 mb-2">
                  <a href="#">Wintech Industries</a>
                </h3>
                <p>HTML, CSS, JS</p>
              </div>
            </div>
            <div class="portfolio-item-single portfolio-pin-box">
              <img src="assets/images/portfolio/pf-3-3.webp" alt="" />
              <div class="portfolio-item-info text-start w-100">
                <h3 class="h3 mb-2">
                  <a href="portfolio-grid.html">DR. Jenit Gandhi</a>
                </h3>
                <p>HTML, CSS, JS</p>
              </div>
            </div>
            <div class="portfolio-item-single portfolio-pin-box">
              <img src="assets/images/portfolio/pf-3-4.webp" alt="" />
              <div class="portfolio-item-info text-start w-100">
                <h3 class="h3 mb-2">
                  <a href="#">Jr. Marvels Preschool</a>
                </h3>
                <p>Wordpress</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
